# Questboard Environment Configuration
# Copy to .env and fill in values

# Server
QUESTBOARD_PORT=7777
QUESTBOARD_HOST=0.0.0.0
QUESTBOARD_DEBUG=true

# Campaign root directory
QUESTBOARD_CAMPAIGN_ROOT=~/DnD Sessions

# JWT Secret (generate a random string for production)
QUESTBOARD_JWT_SECRET=change-me-in-production

# Google Cloud Speech-to-Text (optional — for voice transcription)
QUESTBOARD_GCP_API_KEY=

# Discord Bot Token (optional — for Discord integration)
QUESTBOARD_DISCORD_BOT_TOKEN=
